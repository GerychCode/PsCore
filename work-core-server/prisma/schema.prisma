generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int         @id @default(autoincrement())
  telegramId   Int?        @unique
  avatar       String      @default("")
  firstName    String
  lastName     String
  email        String      @unique
  phone        String?
  address      String?
  passwordHash String
  role         Role        @default(Employe)
  dateOfBirth  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workShift    WorkShift[]
  workSchedule WorkSchedule[]
}

enum Role {
  Employe
  Admin
}

model Department {
  id                  Int      @id @default(autoincrement())
  name                String
  telegramId          Int?     @unique
  weekdaysOpeningTime String   @map("weekdays_opening_time")
  weekdaysClosingTime String   @map("weekdays_closing_time")
  weekendsOpeningTime String   @map("weekends_opening_time")
  weekendsClosingTime String   @map("weekends_closing_time")
  address             String?
  latitude            Float?
  longitude           Float?
  isActive            Boolean? @default(true) @map("is_active")

  shiftDepartments    WorkShift[]
  scheduleDepartments WorkSchedule[]
  scheduleLocks       WorkScheduleLock[]

  @@map("departments")
}

model WorkShift {
  id           Int         @id @default(autoincrement())
  userId       Int         @map("user_id")
  departmentId Int         @map("department_id")
  date         DateTime    @map("date")
  startedAt    String      @map("started_at")
  endTime      String      @map("end_time")
  totalHours   Float       @map("total_hours")
  status       ShiftStatus @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  tags     Tag[]      @relation("ShiftTags")

  @@map("work_shifts")
}

model Tag {
  id          Int    @id @default(autoincrement())
  name        String @unique
  severity    Int    @default(1)
  description String?
  shifts      WorkShift[] @relation("ShiftTags")

  @@map("tags")
}

enum ShiftStatus {
  PENDING
  APPROVED
  REJECTED
}

model WorkSchedule {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  departmentId Int      @map("department_id")
  date         DateTime @map("date")
  startedAt    String   @map("started_at")
  endTime      String   @map("end_time")
  isDayOff     Boolean? @default(false) @map("is_day_off")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  @@map("work_schedule")
}

model WorkScheduleLock {
  id           Int      @id @default(autoincrement())
  departmentId Int      @map("department_id")
  weekStart    DateTime @map("week_start")
  isLocked     Boolean  @default(false) @map("is_locked")

  department   Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, weekStart])
  @@map("work_schedule_locks")
}