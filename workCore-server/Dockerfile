# Використовуємо легкий офіційний образ Node.js
FROM node:20-alpine AS development

# Встановлюємо робочу директорію всередині контейнера
WORKDIR /app

# Копіюємо файли для встановлення залежностей, щоб кешувати цей крок
COPY package*.json ./

# Встановлюємо залежності проекту
RUN npm install

# Копіюємо решту файлів проекту (хоча вони будуть перезаписані volume-ом,
# це корисно для першого білду та кешування)
COPY . .

# Генеруємо Prisma клієнт, якщо ви його використовуєте
# RUN npx prisma generate

# Відкриваємо порт, на якому працюватиме додаток
EXPOSE 3001

# Команда за замовчуванням для запуску dev-сервера.
# Вона буде перевизначена в docker-compose.yml, але це хороший fallback.
CMD ["npm", "run", "start:dev"]
